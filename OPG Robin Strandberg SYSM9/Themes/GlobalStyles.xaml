<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- === COLOR VARIABLES === -->
    <SolidColorBrush x:Key="AppBackground" Color="#F5EFE6" />
    <SolidColorBrush x:Key="PrimaryTitle" Color="#1A1A1A" />
    <SolidColorBrush x:Key="AccentColor" Color="#C0782F" />
    <SolidColorBrush x:Key="AccentColorDark" Color="#9B5510" />
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SubtleText" Color="#666666" />

    <!-- === TEXTBLOCK === -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,6,0,2" />
    </Style>

    <!-- === TEXTBOX — Material Design Outlined === -->
    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Width" Value="300" />
        <Setter Property="Margin" Value="0,2,0,12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- === PASSWORDBOX — Material Design Outlined === -->
    <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
        <Setter Property="Width" Value="300" />
        <Setter Property="Margin" Value="0,2,0,12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- === COMBOBOX — Material Design Outlined === -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Width" Value="300" />
        <Setter Property="Margin" Value="0,2,0,12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- === DATEPICKER — Material Design Outlined === -->
    <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
        <Setter Property="Width" Value="300" />
        <Setter Property="Margin" Value="0,2,0,12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- === BUTTON — Material Design Raised, CookMaster-orange === -->
    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{StaticResource AccentColor}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentColor}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="Segoe UI Semibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="130" />
        <Setter Property="Margin" Value="6,8" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
    </Style>

    <!-- === BUTTON — Outlined (secondary) === -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="BorderBrush" Value="{StaticResource AccentColor}" />
        <Setter Property="Foreground" Value="{StaticResource AccentColor}" />
        <Setter Property="FontFamily" Value="Segoe UI Semibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="130" />
        <Setter Property="Margin" Value="6,8" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
    </Style>

</ResourceDictionary>
